pipeline {

    agent any

    environment {
        IMAGE_NAME = "java-cicd-demo"
        IMAGE_TAG = "1.0"
        REGISTRY = "docker.io/fathimarasheeqa"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t %IMAGE_NAME%:%IMAGE_TAG% .'
            }
        }

        stage('Push Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    bat '''
                        docker login -u %DOCKER_USER% -p %DOCKER_PASS%
                        docker tag java-cicd-demo:1.0 docker.io/fathimarasheeqa/java-cicd-demo:1.0
                        docker push docker.io/fathimarasheeqa/java-cicd-demo:1.0
                    '''
                }
            }
        }
        stage('Check Kubernetes in Jenkins') {
            steps {
                bat 'kubectl version --client'
                bat 'kubectl config current-context'
                bat 'kubectl get nodes'
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                   bat 'kubectl config current-context'
                    bat 'kubectl get nodes'
                    bat 'kubectl apply -f k8s\\deployment.yaml'
                    bat 'kubectl apply -f k8s\\service.yaml'
                }
        }
        stage('Sanity Check') {
            steps {
                bat '''
                start /B kubectl port-forward svc/java-cicd-demo-service 9090:8080
                ping 127.0.0.1 -n 6 > nul
                curl -f http://localhost:9090/wrong-url
                '''
            }
        }
    }
    post {

        failure {

            echo 'Rollback started'

            bat '''
                kubectl rollout undo deployment/java-cicd-demo
                kubectl rollout status deployment/java-cicd-demo
            '''
        }

    }
}